#!/usr/bin/env python3
"""Show support and bug-reporting info for installed vendors.

Usage:
    python3 .vendored/feedback              # all vendors
    python3 .vendored/feedback <vendor>     # specific vendor
"""

import json
import os
import sys


CONFIGS_DIR = ".vendored/configs"
CONFIG_PATH = ".vendored/config.json"
MANIFESTS_DIR = ".vendored/manifests"

# Registry fields (same set as install script)
REGISTRY_FIELDS = {"repo", "install_branch", "protected", "allowed",
                   "private", "automerge", "dogfood", "dependency_mode",
                   "support"}


def _read_registry(vendor_name):
    """Read vendor registry from .vendored/manifests/<vendor>.registry."""
    registry_path = os.path.join(MANIFESTS_DIR, f"{vendor_name}.registry")
    if not os.path.isfile(registry_path):
        return None
    with open(registry_path) as f:
        return json.load(f)


def _extract_vendor_registry(raw, vendor_name=None):
    """Extract registry fields from a per-vendor config.

    Prefers .registry file in manifests/ (new path). Falls back to _vendor
    key in config, then treats all top-level keys as registry fields.
    """
    if vendor_name:
        registry = _read_registry(vendor_name)
        if registry is not None:
            return registry
    if "_vendor" in raw:
        return dict(raw["_vendor"])
    return dict(raw)


def load_vendors():
    """Load all vendor configs. Returns dict of {name: config}."""
    vendors = {}

    if os.path.isdir(CONFIGS_DIR):
        json_files = [f for f in os.listdir(CONFIGS_DIR) if f.endswith(".json")]
        if json_files:
            for filename in sorted(json_files):
                vendor_name = filename[:-5]
                filepath = os.path.join(CONFIGS_DIR, filename)
                with open(filepath) as f:
                    raw = json.load(f)
                vendors[vendor_name] = _extract_vendor_registry(raw, vendor_name)
            return vendors

    if os.path.isfile(CONFIG_PATH):
        with open(CONFIG_PATH) as f:
            config = json.load(f)
        return config.get("vendors", {})

    return vendors


def get_installed_vendors():
    """Return set of vendor names that have a .version file in manifests."""
    installed = set()
    if os.path.isdir(MANIFESTS_DIR):
        for f in os.listdir(MANIFESTS_DIR):
            if f.endswith(".version"):
                installed.add(f[:-8])
    return installed


def get_support_info(vendor_name, vendor_config):
    """Get support info for a vendor, with smart defaults."""
    support = vendor_config.get("support", {})
    repo = vendor_config.get("repo", "")

    issues_url = support.get("issues", "")
    if not issues_url and repo:
        issues_url = f"https://github.com/{repo}/issues"

    instructions = support.get("instructions", "")
    labels = support.get("labels", [])

    return {
        "issues": issues_url,
        "instructions": instructions,
        "labels": labels,
    }


def get_version(vendor_name):
    """Read installed version from manifests."""
    version_path = os.path.join(MANIFESTS_DIR, f"{vendor_name}.version")
    if os.path.isfile(version_path):
        return open(version_path).read().strip()
    return None


def print_vendor_feedback(vendor_name, vendor_config):
    """Print support info for a single vendor."""
    info = get_support_info(vendor_name, vendor_config)
    version = get_version(vendor_name)
    repo = vendor_config.get("repo", "unknown")

    print(f"  {vendor_name}")
    print(f"    repo:    {repo}")
    if version:
        print(f"    version: {version}")
    if info["issues"]:
        print(f"    issues:  {info['issues']}")
    if info["instructions"]:
        print(f"    info:    {info['instructions']}")
    if info["labels"]:
        print(f"    labels:  {', '.join(info['labels'])}")
    print()


def main():
    target = sys.argv[1] if len(sys.argv) > 1 else None

    vendors = load_vendors()
    installed = get_installed_vendors()

    if target:
        if target not in vendors:
            print(f"Unknown vendor: {target}", file=sys.stderr)
            print(f"Installed vendors: {', '.join(sorted(installed))}", file=sys.stderr)
            sys.exit(1)
        print("Vendor support info:")
        print()
        print_vendor_feedback(target, vendors[target])
    else:
        # Show all installed vendors
        active = {name: cfg for name, cfg in vendors.items() if name in installed}
        if not active:
            print("No installed vendors found.")
            return

        print("Vendor support info:")
        print()
        for name in sorted(active):
            print_vendor_feedback(name, active[name])


if __name__ == "__main__":
    main()
