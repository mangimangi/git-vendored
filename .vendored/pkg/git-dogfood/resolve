#!/usr/bin/env python3
"""Dogfood resolver — derives the vendor name from GITHUB_REPOSITORY.

Convention: the vendor name is the repository name (the part after '/').
For GITHUB_REPOSITORY=acme/my-tool, the vendor is "my-tool".

Outputs the vendor name in GITHUB_OUTPUT format (vendor=<name>).

Usage:
    python3 .vendored/pkg/git-dogfood/resolve

Exit codes:
    0 - Always (outputs vendor=<name> if set, empty otherwise)
"""

import os
import sys


def vendor_from_repo(github_repo):
    """Derive vendor name from a GitHub repository slug.

    Convention: vendor name = repo name (part after '/').
    """
    return github_repo.split("/")[-1]


def main():
    github_repo = os.environ.get("GITHUB_REPOSITORY", "")
    if not github_repo:
        print("GITHUB_REPOSITORY not set", file=sys.stderr)
        return

    vendor = vendor_from_repo(github_repo)
    print(f"vendor={vendor}")


if __name__ == "__main__":
    main()
