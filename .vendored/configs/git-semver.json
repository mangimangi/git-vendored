{
  "_vendor": {
    "repo": "mangimangi/git-semver",
    "install_branch": "chore/install-git-semver",
    "protected": [
      ".semver/**",
      ".github/workflows/version-bump.yml",
      ".github/workflows/release.yml"
    ],
    "allowed": [
      ".vendored/configs/git-semver.json"
